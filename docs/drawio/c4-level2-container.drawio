          <mxGeometry x="50" y="280" width="850" height="450" as="geometry" />
        </mxCell>

        <!-- Container: React SPA (top-left inside boundary) -->
        <mxCell id="5" value="&lt;b&gt;React SPA&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;[Container: React 18, Vite, Tailwind CSS, React Router v6]&lt;br/&gt;&lt;br/&gt;Delivers the 7-step wizard UI with interactive charts, sliders, data tables, and visualizations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#3A7BBD;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="320" width="230" height="140" as="geometry" />
        </mxCell>

        <!-- Container: FastAPI Backend (center inside boundary) -->
        <mxCell id="6" value="&lt;b&gt;FastAPI Backend&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;[Container: Python 3.10+, FastAPI 0.110+, Uvicorn 0.29+]&lt;br/&gt;&lt;br/&gt;REST API providing endpoints for data upload, preprocessing, model training, predictions, explainability, and bias auditing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#3A7BBD;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="360" y="320" width="230" height="140" as="geometry" />
        </mxCell>

        <!-- Container: ML Engine (top-right inside boundary) -->
        <mxCell id="7" value="&lt;b&gt;ML Engine&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;[Container: scikit-learn 1.4+, SHAP 0.45+, imbalanced-learn 0.12+]&lt;br/&gt;&lt;br/&gt;Trains 6 ML algorithms, computes performance metrics, generates SHAP explanations, and performs subgroup fairness audits" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#3A7BBD;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="640" y="320" width="230" height="140" as="geometry" />
        </mxCell>

        <!-- Container: Clinical Datasets (bottom-left, cylinder) -->
        <mxCell id="8" value="&lt;b&gt;Clinical Datasets&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;[Data Store: 20 CSV Files]&lt;br/&gt;&lt;br/&gt;Pre-loaded patient datasets covering Cardiology, Nephrology, Oncology, Neurology, Diabetes, and 15 more clinical domains" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#3A7BBD;align=center;fontSize=11;size=15;boundedLbl=1;" vertex="1" parent="1">
