        <mxCell id="person1" value="&lt;div style=&quot;margin-top:44px;&quot;&gt;&lt;b style=&quot;font-size:15px;&quot;&gt;Healthcare&lt;br&gt;Professional&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#CBD5E1;&quot;&gt;[Person]&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;Doctor, nurse, or clinical&lt;br&gt;researcher who needs to&lt;br&gt;understand ML predictions&lt;br&gt;for clinical decisions&lt;/font&gt;&lt;/div&gt;" style="shape=mxgraph.c4.person2;whiteSpace=wrap;html=1;fillColor=#08427B;fontColor=#ffffff;rounded=1;align=center;metaEdit=1;points=[[0.5,0,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0]];strokeColor=#052E56;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="230" y="120" width="250" height="220" as="geometry"/>
        </mxCell>

        <mxCell id="person2" value="&lt;div style=&quot;margin-top:44px;&quot;&gt;&lt;b style=&quot;font-size:15px;&quot;&gt;Student / Instructor&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#CBD5E1;&quot;&gt;[Person]&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;SENG 430 course participant&lt;br&gt;using the tool for teaching&lt;br&gt;and learning ML concepts&lt;br&gt;in a healthcare setting&lt;/font&gt;&lt;/div&gt;" style="shape=mxgraph.c4.person2;whiteSpace=wrap;html=1;fillColor=#08427B;fontColor=#ffffff;rounded=1;align=center;metaEdit=1;points=[[0.5,0,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0]];strokeColor=#052E56;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="890" y="120" width="250" height="220" as="geometry"/>
        </mxCell>

        <mxCell id="system" value="&lt;b style=&quot;font-size:18px;&quot;&gt;HealthWithSevgi&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px;color:#B8D4F0;&quot;&gt;[Software System]&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px;&quot;&gt;Interactive browser-based ML visualization tool&lt;br&gt;guiding users through a 7-step pipeline from&lt;br&gt;medical specialty selection to model training&lt;br&gt;to fairness auditing &amp;mdash; no coding required&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#3A7BBD;align=center;shadow=1;arcSize=6;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="450" y="440" width="480" height="180" as="geometry"/>
