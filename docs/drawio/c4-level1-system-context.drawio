        </mxCell>
        <mxCell id="subtitle" value="&lt;font style=&quot;font-size:14px;color:#888888;&quot;&gt;HealthWithSevgi  |  ML Visualization Tool for Healthcare  |  SENG 430&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
