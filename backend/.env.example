# Copy this file to .env and fill in your values
# DO NOT commit .env to git — it contains secrets

# Gemini API (primary LLM provider for clinical insights)
# Default model is Gemini 2.5 Flash.
# Any model exposed via Google AI Studio works (e.g., gemini-2.5-flash, gemma-4-31b-it).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# HuggingFace token (required for gated models like MedGemma)
HF_TOKEN=

# MedGemma via Vertex AI (optional, requires deployed endpoint)
# GOOGLE_CLOUD_PROJECT=
# VERTEX_AI_LOCATION=us-central1
# MEDGEMMA_ENDPOINT_ID=
